# ============================================
# Application
# ============================================

APP_NAME=Agentic AI Backend
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# ============================================
# Server
# ============================================

HOST=127.0.0.1
PORT=8000

# ============================================
# LLM
# ============================================

LLM_PROVIDER=gemini

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ============================================
# GitHub
# ============================================

GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# ============================================
# Jira
# ============================================

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ============================================
# Database (Future)
# ============================================

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=agentic_ai
MYSQL_USERNAME=root
MYSQL_PASSWORD=password